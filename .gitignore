# Godot 4.5 defaults
.godot/
.import/
export.cfg
export_presets.cfg
*.translation

# Mono / C# (unused but defensive)
.mono/
data_*/
mono_crash.*.json

# OS / editor cruft
.DS_Store
.vscode/
.idea/
__pycache__/
*.py[cod]
*.bak

# Local agent runtime state
.claire/
.claude/settings.local.json
.claude/worktrees/

# GUT plugin runtime cache
addons/gut/.cache/

# Local plan / scratch
/scratch/
harness/comms/

# Harness Plan 3 runtime
/.worktrees/
harness/runs/*/
!harness/runs/.gitkeep

# Harness Plan 4 runtime (per-sprint grading artifacts live under harness/runs/, already ignored)
# Strategy session logs may be large; explicitly ensure they are not committed.
harness/runs/*/sprint_*/strategy_sessions/
harness/runs/*/sprint_*/traces/

# Harness Plan 5 runtime — per-sprint flock files
harness/.locks/*.lock
!harness/.locks/.gitkeep

# Harness Phase 6 runtime
harness/runs/*/report.html.tmp
harness/runs/*/.run.lock
